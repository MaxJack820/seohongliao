---
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface Props {
  title: string;
  description: string;
  /** schema.org 结构化数据对象,JSON-LD 注入 */
  jsonld?: unknown;
  /** false → 长尾页输出 noindex,follow(合规:薄页防护) */
  index?: boolean;
  ogType?: 'website' | 'article';
}
const { title, description, jsonld, index = true, ogType = 'website' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ctaAnalyticsEndpoint = import.meta.env.PUBLIC_CTA_ANALYTICS_ENDPOINT ?? '';
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  {!index && <meta name="robots" content="noindex, follow" />}
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <link rel="stylesheet" href="/styles.css" />
  {jsonld && <script type="application/ld+json" set:html={JSON.stringify(jsonld)} />}
  <script is:inline define:vars={{ ctaAnalyticsEndpoint }}>
    window.addEventListener('click', (event) => {
      const link = event.target && event.target.closest ? event.target.closest('a[data-cta="funnel"]') : null;
      if (!link) return;
      const payload = {
        type: 'cta_click',
        href: link.href,
        campaign: link.dataset.campaign || '',
        sourcePath: window.location.pathname,
        label: link.dataset.label || link.textContent.trim(),
        ts: Date.now(),
      };
      window.dispatchEvent(new CustomEvent('qiutan:cta-click', { detail: payload }));
      if (!ctaAnalyticsEndpoint || !navigator.sendBeacon) return;
      navigator.sendBeacon(ctaAnalyticsEndpoint, new Blob([JSON.stringify(payload)], { type: 'application/json' }));
    });
  </script>
</head>
<body>
  <SiteHeader />
  <div class="container">
    <slot name="breadcrumb" />
    <div class="layout">
      <slot name="main" />
      <slot name="aside" />
    </div>
  </div>
  <SiteFooter />
</body>
</html>
